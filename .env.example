# mcp-trino-optimizer — Environment Variable Reference
# Copy this file to .env and fill in values.
# .env is git-ignored; .env.example is committed.
# Precedence: CLI flags > MCPTO_* env vars > .env file > defaults

# ──────────────────────────────────────────────────────────────
# Transport
# ──────────────────────────────────────────────────────────────

# Which MCP transport to serve on. One of: stdio, http
# Default: stdio
MCPTO_TRANSPORT=stdio

# Bind address for Streamable HTTP transport.
# Default: 127.0.0.1 (localhost only — safe default)
# Set to 0.0.0.0 only if you are running behind a reverse proxy with TLS.
MCPTO_HTTP_HOST=127.0.0.1

# Port for Streamable HTTP transport. Valid range 1-65535.
# Default: 8080
MCPTO_HTTP_PORT=8080

# Static bearer token for Streamable HTTP transport.
# REQUIRED when MCPTO_TRANSPORT=http.
# Generate a strong token with: openssl rand -hex 32
# NEVER commit the real value. Use your secret manager.
# MCPTO_HTTP_BEARER_TOKEN=<run: openssl rand -hex 32>

# ──────────────────────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────────────────────

# Logging level. One of: DEBUG, INFO, WARNING, ERROR
# Default: INFO
MCPTO_LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────
# Build-time injection (optional; not read from .env in practice)
# ──────────────────────────────────────────────────────────────

# Git SHA baked in at build time (for observability).
# Phase 1 falls back to runtime git rev-parse or "unknown".
# MCPTO_GIT_SHA=abc123456789

# ──────────────────────────────────────────────────────────────
# Trino Connection (Phase 2)
# ──────────────────────────────────────────────────────────────

# Trino coordinator hostname. Required for live mode.
# MCPTO_TRINO_HOST=localhost

# Trino coordinator port. Default: 8080
# MCPTO_TRINO_PORT=8080

# Default Trino catalog. Default: iceberg
# MCPTO_TRINO_CATALOG=iceberg

# Default Trino schema (optional).
# MCPTO_TRINO_SCHEMA=

# Trino authentication mode. One of: none, basic, jwt. Default: none
# MCPTO_TRINO_AUTH_MODE=none

# Trino user for basic auth (required when MCPTO_TRINO_AUTH_MODE=basic).
# MCPTO_TRINO_USER=

# Trino password for basic auth (required when MCPTO_TRINO_AUTH_MODE=basic).
# MCPTO_TRINO_PASSWORD=

# Trino JWT token for jwt auth (required when MCPTO_TRINO_AUTH_MODE=jwt).
# MCPTO_TRINO_JWT=

# Verify SSL certificates for Trino connections. Default: true
# MCPTO_TRINO_VERIFY_SSL=true

# Path to CA bundle for Trino TLS (optional).
# MCPTO_TRINO_CA_BUNDLE=

# Wall-clock timeout per Trino query in seconds. Default: 60
# MCPTO_TRINO_QUERY_TIMEOUT_SEC=60

# Max concurrent Trino queries per MCP process. Default: 4
# MCPTO_MAX_CONCURRENT_QUERIES=4
